{
  "name": "disagreement-ai-monorepo",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "client",
    "server"
  ],
  "scripts": {
    "install:all": "npm install",
    "dev": "concurrently \"npm run dev -w client\" \"npm run dev -w server\"",
    "build:client": "npm run build -w client"
  },
  "devDependencies": {
    "concurrently": "^9.2.1"
  }
}
